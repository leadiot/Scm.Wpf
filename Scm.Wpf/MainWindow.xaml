<hc:Window
    x:Class="Com.Scm.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Com.Scm.Wpf.Views.Uc"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    mc:Ignorable="d"
    Icon="/Resources/logo.ico"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource ScmWindowBackground}"
    Title="Scm.Net"
    Width="960" Height="640"
    MinHeight="400" MinWidth="840">
    <hc:Window.InputBindings>
        <KeyBinding Key="F1" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="F2" Modifiers="Ctrl" Command="{Binding OpenDataCommand}"/>
    </hc:Window.InputBindings>
    <hc:Window.NonClientAreaContent >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Button>
                    <iconPacks:PackIconMaterial Kind="Menu" Width="12" Height="12" />
                </Button>
            </Grid>
        </Grid>
    </hc:Window.NonClientAreaContent>
    <Border MouseLeftButtonDown="Border_MouseLeftButtonDown" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <!-- 菜单栏 -->
            <uc:UcMenubarView x:Name="UcMenu" Grid.Row="0" Visibility="Collapsed" />
            <!-- 信息栏 -->
            <uc:UcInfobarView x:Name="UcInfo" Grid.Row="1"/>
            <DockPanel Grid.Row="2">
                <!-- 导航栏 -->
                <uc:UcGuidView x:Name="UcGuid" DockPanel.Dock="Left" />
                <!-- 侧边栏 -->
                <uc:UcSideView x:Name="UcSide" DockPanel.Dock="Right"/>
                <!-- 内容 -->
                <hc:TabControl 
                        Name="TcView"
                        TabItemWidth="120"
                        Foreground="#5a5e66"
                        IsAnimationEnabled="True"
                        ShowCloseButton="True"
                        IsDraggable="True"
                        SelectedIndex="{Binding TabIndex}"
                        ItemsSource="{Binding TabModels}"
                        OverflowMenuDisplayMemberPath="Header">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Header}"/>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource ScmWindowBackground}">
                                <ContentControl Grid.Row="1" Grid.Column="1"  Content="{Binding Content}" Margin="4 6"/>
                            </Border>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </hc:TabControl>
            </DockPanel>

            <!-- 任务栏 -->
            <uc:UcTraybarView x:Name="UcTray" Grid.Row="3" />

            <!-- 窗口遮罩层 -->
            <Grid x:Name="GdToast"></Grid>

            <!-- 系统托盘图标 -->
            <hc:NotifyIcon
                x:Name="TiTask"
                Token="Nas.Net"
                Text="Nas.Net"
                IsBlink="{Binding IsBlink}"
                Visibility="{Binding TrayVisibility}"
                MouseDoubleClick="TiTask_MouseDoubleClick">
                <hc:NotifyIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="MiMain" Click="MiMain_Click" Header="显示主窗口"/>
                        <Separator/>
                        <MenuItem x:Name="MiLogout" Click="MiLogout_Click" Header="退出登录"/>
                        <Separator/>
                        <MenuItem x:Name="MiExit" Click="MiExit_Click" Header="退出应用"/>
                    </ContextMenu>
                </hc:NotifyIcon.ContextMenu>
            </hc:NotifyIcon>
        </Grid>
    </Border>
</hc:Window>
