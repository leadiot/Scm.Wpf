<hc:Window
    x:Class="Com.Scm.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:Uc="clr-namespace:Com.Scm.Wpf.Views.Uc"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    mc:Ignorable="d"
    WindowStartupLocation="CenterScreen"
    Title="MainWindow"
    Height="600"
    Width="800">
    <hc:Window.NonClientAreaContent >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Button>
                    <iconPacks:PackIconMaterial Kind="Menu" Width="12" Height="12" />
                </Button>
            </Grid>
        </Grid>
    </hc:Window.NonClientAreaContent>
    <DockPanel Background="White">
        <Uc:UcMenubarView x:Name="UcMenu" DockPanel.Dock="Top" />
        <Uc:UcInfobarView x:Name="UcInfo" DockPanel.Dock="Bottom" />
        <Uc:UcGuidView x:Name="UcGuid" DockPanel.Dock="Left" />
        <Uc:UcSideView x:Name="UcSide" DockPanel.Dock="Right"/>
        <Grid>
            <Uc:UcDataView />
        </Grid>
    </DockPanel>
</hc:Window>
