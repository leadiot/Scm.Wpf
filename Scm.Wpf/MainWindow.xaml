<hc:Window
    x:Class="Com.Scm.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Com.Scm.Wpf.Views.Uc"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    mc:Ignorable="d"
    Title="Scm.Net"
    Icon="/Resources/logo.ico"
    WindowStartupLocation="CenterScreen"
    Width="960" Height="640"
    MinHeight="400" MinWidth="840">
    <hc:Window.InputBindings>
        <KeyBinding Key="F1" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="F2" Modifiers="Ctrl" Command="{Binding OpenDataCommand}"/>
    </hc:Window.InputBindings>
    <hc:Window.NonClientAreaContent >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Button>
                    <iconPacks:PackIconMaterial Kind="Menu" Width="12" Height="12" />
                </Button>
            </Grid>
        </Grid>
    </hc:Window.NonClientAreaContent>
    <Border MouseLeftButtonDown="Border_MouseLeftButtonDown" Background="White">
        <Grid>
            <DockPanel>
                <uc:UcMenubarView x:Name="UcMenu" DockPanel.Dock="Top" Visibility="Collapsed" />
                <uc:UcTraybarView x:Name="UcTray" DockPanel.Dock="Bottom" />
                <uc:UcGuidView x:Name="UcGuid" DockPanel.Dock="Left" />
                <uc:UcSideView x:Name="UcSide" DockPanel.Dock="Right"/>
                <DockPanel>
                    <uc:UcInfobarView x:Name="UcInfo" DockPanel.Dock="Top"/>
                    <hc:TabControl 
                        Name="TcView"
                        Margin="4"
                        TabItemWidth="120"
                        Foreground="#5a5e66"
                        IsAnimationEnabled="True"
                        ShowCloseButton="True"
                        IsDraggable="True"
                        SelectedIndex="{Binding TabIndex}"
                        ItemsSource="{Binding TabModels}"
                        OverflowMenuDisplayMemberPath="Header">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Header}"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Border Background="White">
                                    <ContentControl Grid.Row="1" Grid.Column="1"  Content="{Binding Content}" Margin="4 6"/>
                                </Border>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </hc:TabControl>
                </DockPanel>
            </DockPanel>
            <Grid x:Name="GdToast"></Grid>
        </Grid>
    </Border>
</hc:Window>
