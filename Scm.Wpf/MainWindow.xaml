<hc:Window
    x:Class="Com.Scm.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Com.Scm.Wpf.Views.Uc"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    mc:Ignorable="d"
    WindowStartupLocation="CenterScreen"
    Title="MainWindow"
    Height="600"
    Width="800">
    <hc:Window.NonClientAreaContent >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Button>
                    <iconPacks:PackIconMaterial Kind="Menu" Width="12" Height="12" />
                </Button>
            </Grid>
        </Grid>
    </hc:Window.NonClientAreaContent>
    <Border Margin="5"  CornerRadius="10" MouseLeftButtonDown="Border_MouseLeftButtonDown" Background="White">
        <Border.Effect>
            <DropShadowEffect Color="Gray" ShadowDepth="0" BlurRadius="5" Opacity="0.5" Direction="0"/>
        </Border.Effect>
        <DockPanel>
            <uc:UcMenubarView x:Name="UcMenu" DockPanel.Dock="Top" Visibility="Collapsed" />
            <uc:UcTraybarView x:Name="UcTray" DockPanel.Dock="Bottom" />
            <uc:UcGuidView x:Name="UcGuid" DockPanel.Dock="Left" />
            <uc:UcSideView x:Name="UcSide" DockPanel.Dock="Right"/>
            <DockPanel>
                <uc:UcInfobarView x:Name="UcInfo" DockPanel.Dock="Top"/>
                <hc:TabControl 
                    Name="TcView"
                    Margin="0"
                    TabItemWidth="100"
                    IsAnimationEnabled="True" 
                    BorderBrush="{x:Null}"
                    Foreground="#5a5e66"
                    ShowCloseButton="True" 
                    IsDraggable="True" 
                    Opacity="1"
                    Panel.ZIndex="997"
                    Background="White"
                    SelectedIndex="{Binding TabIndex}"
                    ItemsSource="{Binding TabModels}"
                    Style="{DynamicResource MyTabControlStyle}">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Header}"/>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <ContentControl Grid.Row="1" Grid.Column="1"  Content="{Binding Content}" Background="White" Margin="0 12 0 0"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </hc:TabControl>
            </DockPanel>
        </DockPanel>
    </Border>
</hc:Window>
