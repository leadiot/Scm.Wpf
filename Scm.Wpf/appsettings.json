{
  "Serilog": {
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "MinimumLevel": "Information",
    "Properties": {
      "Application": "C-SCM"
    },
    "Using": [ "Serilog.Sinks.File" ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Env": {
    "dataUri": "/data",
    "dataDir": "data",
    "upload": "upload",
    "images": "images",
    "logs": "logs"
  },
  "Sql": {
    "Type": "MySQL",
    "Text": "server=127.0.0.1;database=scm;uid=root;pwd=Scm.1234;charset='utf8';SslMode=None;"
  },
  "Uid": {
    "Type": "Compose",
    "DbType": "MySql",
    "DbText": "server=127.0.0.1;database=scm;uid=root;pwd=Scm.1234;charset='utf8';SslMode=None;"
  },
  "Oidc": {
    "app_key": "",
    "app_secret": "",
    "redirect_uri": "http://localhost:2800/oauth/callback",
    "scope": "openid"
  }
}