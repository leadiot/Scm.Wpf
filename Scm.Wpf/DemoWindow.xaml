<hc:Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    x:Class="Com.Scm.DemoWindow"
    mc:Ignorable="d"
    Title="现代化企业系统" Height="700" Width="1000"
    Background="#f5f8fa">

    <Window.Resources>
        <!-- 颜色定义 -->
        <SolidColorBrush x:Key="SidebarBg" Color="#1A68B8"/>
        <!-- 深色背景 -->
        <SolidColorBrush x:Key="SidebarHover" Color="#2b2b40"/>
        <!-- 悬停背景 -->
        <SolidColorBrush x:Key="SidebarActive" Color="#3699ff"/>
        <!-- 选中高亮色 (蓝色) -->
        <SolidColorBrush x:Key="TextMain" Color="#ffffff"/>
        <!-- 主要文字 -->
        <SolidColorBrush x:Key="TextMuted" Color="#a1a5b7"/>
        <!-- 次要文字/箭头 -->
        <ContextMenu x:Key="ListBoxMenu">
            <MenuItem x:Name="MiOpen" Header="打开" Command="{Binding OpenFileCommand}" CommandParameter="{Binding}"></MenuItem>
            <Separator/>
            <MenuItem x:Name="MiExplorer" Header="在文件资源管理器中打开" Click="MiExplorer_Click"></MenuItem>
            <Separator/>
            <MenuItem Name="MiCreateDir" Header="新建目录" Click="MiCreateDir_Click"></MenuItem>
            <MenuItem Name="MiCreateDoc" Header="新建文档" Click="MiCreateDoc_Click"></MenuItem>
            <MenuItem Name="MiEdit" Header="编辑" Click="MiEdit_Click"></MenuItem>
            <MenuItem Name="MiDelete" Header="删除" Click="MiDelete_Click"></MenuItem>
        </ContextMenu>
    </Window.Resources>

    <ListBox
        x:Name="LbFile"
        ItemsSource="{Binding FileList}"
        SelectedItem="{Binding CurrentFile}"
        SelectionMode="Single"
        MouseDoubleClick="LbFile_MouseDoubleClick">
        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="ContextMenu" Value="{StaticResource ListBoxMenu}"/>
            </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="6">
                    <iconPacks:PackIconMaterial Kind="{Binding Icon}" Foreground="{Binding Color}" Margin="6" />
                    <TextBlock Text="{Binding Name}" Margin="6"></TextBlock>
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</hc:Window>
