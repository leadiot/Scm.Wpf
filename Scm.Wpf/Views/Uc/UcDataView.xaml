<UserControl x:Class="Com.Scm.Wpf.Views.Uc.UcDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:Uc="clr-namespace:Com.Scm.Wpf.Views.Uc"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <hc:ButtonGroup>
                    <Button ToolTip="新增">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="16" Height="16" />
                    </Button>
                </hc:ButtonGroup>
                <hc:Divider Orientation="Vertical"/>
                <hc:ButtonGroup>
                    <Button ToolTip="启用">
                        <iconPacks:PackIconMaterial Kind="CheckboxOutline" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip="禁用">
                        <iconPacks:PackIconMaterial Kind="CloseBoxOutline" Width="16" Height="16" />
                    </Button>
                    <Button ToolTip="删除">
                        <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="16" Height="16" Foreground="Red" />
                    </Button>
                </hc:ButtonGroup>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBox x:Name="TbMeta" Width="140"/>
                <Button x:Name="BtSearch" Content="搜索"></Button>
                <hc:Divider Orientation="Vertical"/>
                <ToggleButton x:Name="BtMore" Content="显示" Click="BtMore_Click"></ToggleButton>
            </StackPanel>
        </Grid>
        <Uc:UcPageData Grid.Row="1" Margin="5"/>
        <Popup x:Name="PwForm"
               Placement="Right"
               AllowsTransparency="True"
               PopupAnimation="Slide"
               HorizontalOffset="-200"
               VerticalOffset="20"
               Margin="10"
               Width="200">
            <Grid Background="Red">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <hc:TextBox Grid.Row="0" Grid.Column="1" hc:InfoElement.TitleWidth="60" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="123" Text="Abc"/>
                <hc:TextBox Grid.Row="1" Grid.Column="1" hc:InfoElement.TitleWidth="60" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="123" Text="Abc"/>
                <hc:TextBox Grid.Row="2" Grid.Column="1" hc:InfoElement.TitleWidth="60" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="123" Text="Abc"/>
                <hc:TextBox Grid.Row="3" Grid.Column="1" hc:InfoElement.TitleWidth="60" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="123" Text="Abc"/>
                <hc:TextBox Grid.Row="4" Grid.Column="1" hc:InfoElement.TitleWidth="60" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="123" Text="Abc"/>
            </Grid>
        </Popup>
    </Grid>
</UserControl>
