<UserControl
    x:Class="Com.Scm.Wpf.Views.Uc.UcGuidView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:template="clr-namespace:Com.Scm.Wpf.Controls.Template"
    xmlns:converter="clr-namespace:Com.Scm.Wpf.Converters"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <UserControl.Resources>
        <converter:ParameterConverter x:Key="ParameterConvert"></converter:ParameterConverter>
        <DataTemplate x:Key="expanderTemplate">
            <Expander BorderThickness="0" Background="Transparent" Foreground="#BFCBD9" Margin="0 20 0 0">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="{Binding Icon}" Foreground="#BFCBD9" />
                        <TextBlock FontSize="15" Text="{Binding GroupName}" Foreground="#BFCBD9" Margin="16,2,0,0">
                        </TextBlock>
                    </StackPanel>
                </Expander.Header>
                <Expander.Content>
                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton
                                    Margin="20,15,0,0"
                                    Width="190"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Background="Transparent"
                                    BorderBrush="{x:Null}"
                                    FontSize="13"
                                    GroupName="menu"
                                    Command="{Binding DataContext.changeContentCmd,RelativeSource={RelativeSource AncestorType=Window,Mode=FindAncestor}}"
                                    Style="{StaticResource RadioButtonIcon}">
                                    <RadioButton.CommandParameter>
                                        <MultiBinding Converter="{StaticResource ParameterConvert}">
                                            <Binding  Path="TypeName"/>
                                            <Binding  Path="Name"/>
                                        </MultiBinding>
                                    </RadioButton.CommandParameter>
                                    <RadioButton.Content>
                                        <WrapPanel  Width="190">
                                            <iconPacks:PackIconMaterial Kind="{Binding Icon}" Foreground="#BFCBD9" />
                                            <TextBlock FontSize="13" Text="{Binding Name}" Margin="5 2 0 0" Foreground="#BFCBD9"></TextBlock>
                                        </WrapPanel>
                                    </RadioButton.Content>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander.Content>
            </Expander>
        </DataTemplate>
        <DataTemplate x:Key="groupTemplate">
            <StackPanel HorizontalAlignment="Center" Margin="0 20 0 0">
                <Button Height="30" Width="30"  HorizontalAlignment="Center" VerticalAlignment="Center" Click="Button_Click_1" >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Grid x:Name="gridtemp">
                                            <iconPacks:PackIconMaterial Kind="{Binding Icon}" Foreground="#BFCBD9" />
                                            <Popup x:Name="menuPop" PlacementTarget="{Binding ElementName=menuIcon}" 
                                                   Grid.Row="1" StaysOpen="False" 
                                                   Placement="Right" 
                                                   Height="auto" 
                                                   Width="180"
                                                   HorizontalOffset="20"
                                                   PopupAnimation="Fade">
                                                <Border Background="#243A56" CornerRadius="5">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 0 15">
                                                        <ItemsControl ItemsSource="{Binding Modules}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <VirtualizingStackPanel/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <RadioButton Margin="20,15,0,0"
                                                                     Width="190"
                                                                     VerticalAlignment="Center"
                                                                     HorizontalAlignment="Left"
                                                                     Background="Transparent"
                                                                     BorderBrush="{x:Null}"
                                                                     FontSize="13"
                                                                     GroupName="menu"
                                                                     Command="{Binding DataContext.changeContentCmd,RelativeSource={RelativeSource AncestorType=Window,Mode=FindAncestor}}"
                                                                     Style="{StaticResource RadioButtonIcon}" >
                                                                        <RadioButton.CommandParameter>
                                                                            <MultiBinding Converter="{StaticResource ParameterConvert}">
                                                                                <Binding  Path="TypeName"/>
                                                                                <Binding  Path="Name"/>
                                                                            </MultiBinding>
                                                                        </RadioButton.CommandParameter>
                                                                        <RadioButton.Content>
                                                                            <WrapPanel  Width="190">
                                                                                <iconPacks:PackIconMaterial Kind="{Binding Icon}" Foreground="#BFCBD9" />
                                                                                <TextBlock FontSize="13" Text="{Binding Name}" Margin="5 2 0 0" Foreground="#BFCBD9"></TextBlock>
                                                                            </WrapPanel>
                                                                        </RadioButton.Content>
                                                                    </RadioButton>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </DataTemplate>
        <!-- 菜单项样式 -->
        <Style x:Key="MenuButtonStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 选中指示器 -->
                                <Border x:Name="SelectionIndicator"
                                        Grid.Column="0" 
                                        Background="#FF3385FF"
                                        HorizontalAlignment="Left"
                                        Height="24"
                                        Visibility="Hidden"/>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"></RowDefinition>
                                        <RowDefinition Height="auto"></RowDefinition>
                                    </Grid.RowDefinitions>

                                    <!-- 图标 -->
                                    <Viewbox Grid.Row="0" Width="24" Height="24" Margin="10">
                                        <ContentControl Content="{Binding Icon}"/>
                                    </Viewbox>

                                    <!-- 文本 -->
                                    <TextBlock
                                        Grid.Row="1" 
                                        Text="{Binding namec}"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        Foreground="#FFFFFF"/>
                                </Grid>

                                <!-- 悬停效果 -->
                                <Border x:Name="HoverOverlay"
                                        Grid.ColumnSpan="2" 
                                        Background="#20000000"
                                        Opacity="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="#243A56" x:Name="menu" Panel.ZIndex="999" CornerRadius="10" HorizontalAlignment="Left" Width="200" >
        <Border.Effect>
            <DropShadowEffect Color="#243A56" ShadowDepth="0" BlurRadius="10" Opacity="0.8" Direction="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="ZR" FontWeight="Bold" 
                       FontSize="33" Foreground="#3DD0FB" 
                               TextAlignment="Center"
                               VerticalAlignment="Top"
                                Margin="0 13 0 0"
                       HorizontalAlignment="Center" Height="48"  Width="136"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="40">
                <Image Source="/Assets/Images/avatar.png" Width="40" Height="40" Stretch="Fill">
                    <Image.Clip>
                        <EllipseGeometry RadiusX="20" RadiusY="20" Center="20,20"/>
                    </Image.Clip>
                </Image>
                <StackPanel VerticalAlignment="Center" Margin="5 0 0 0" Name="userName">
                    <TextBlock Text="贾玲" Foreground="#BFCBD9"/>
                    <TextBlock Text="Admin" Foreground="#959595"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="0 20 0 0">
                <ItemsControl ItemsSource="{Binding ModuleGroups}" Grid.Row="1" Name="IC">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplateSelector>
                        <template:MenuTemplateSelector ExpanderTemplate="{StaticResource expanderTemplate}" GroupTemplate="{StaticResource groupTemplate}" />
                    </ItemsControl.ItemTemplateSelector>
                </ItemsControl>
            </StackPanel>
            <DockPanel Grid.Row="2" Visibility="Collapsed">
                <DockPanel DockPanel.Dock="Left" Width="80">
                    <StackPanel DockPanel.Dock="Top">
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom">
                        <Button
                    x:Name="BtMenu"
                    HorizontalAlignment="Stretch"
                    BorderThickness="0"
                    Click="BtMenu_Click">
                            <iconPacks:PackIconMaterial x:Name="PiMenu" Kind="ChevronDoubleLeft" Width="10" Height="10"/>
                        </Button>
                    </StackPanel>
                    <ListBox
                    x:Name="LvMenu"
                    ItemsSource="{Binding MenuList}"
                    ItemContainerStyle="{StaticResource MenuButtonStyle}"
                    BorderThickness="0"
                    SelectionChanged="LvMenu_SelectionChanged">
                    </ListBox>
                </DockPanel>
                <Grid>
                    <hc:SideMenu x:Name="MbMenu" BorderThickness="1" Width="160"></hc:SideMenu>
                </Grid>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
