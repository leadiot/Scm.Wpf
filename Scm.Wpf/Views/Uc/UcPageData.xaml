<UserControl x:Class="Com.Scm.Wpf.Views.Uc.UcPageData"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>
        <Grid DockPanel.Dock="Bottom" Margin="5 5 5 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <hc:ButtonGroup>
                    <Button x:Name="RbTop">
                        <iconPacks:PackIconMaterial Kind="ChevronDoubleLeft" Width="12" Height="12" />
                    </Button>
                    <Button x:Name="RbPrev">
                        <iconPacks:PackIconMaterial Kind="ChevronLeft" Width="12" Height="12" />
                    </Button>
                    <RadioButton x:Name="RbPage1" Content="1" IsChecked="True"/>
                    <RadioButton x:Name="RbPage2" Content="2"/>
                    <RadioButton x:Name="RbPage3" Content="3"/>
                    <RadioButton x:Name="RbPage4" Content="4"/>
                    <RadioButton x:Name="RbPage5" Content="..."/>
                    <Button x:Name="BtNext">
                        <iconPacks:PackIconMaterial Kind="ChevronRight" Width="12" Height="12" />
                    </Button>
                    <Button x:Name="BtEnd">
                        <iconPacks:PackIconMaterial Kind="ChevronDoubleRight" Width="12" Height="12" />
                    </Button>
                </hc:ButtonGroup>
                <TextBlock>
                    共888页
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <hc:ButtonGroup>
                    <Button Content="列表" ToolTip="列表"/>
                    <Button Content="单页" ToolTip="单页"/>
                </hc:ButtonGroup>
                <Button Content="刷新" ToolTip="刷新"/>
                <Button Content="打印" ToolTip="打印"/>
                <Button Content="选项" ToolTip="选项"/>
            </StackPanel>
        </Grid>
        <DataGrid x:Name="DgGrid"></DataGrid>
    </DockPanel>
</UserControl>
