<Window x:Class="Com.Scm.Views.Text.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="WPF文本编辑器"
        Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 顶部菜单 -->
        <Menu Grid.Row="0">
            <MenuItem Header="文件(_F)">
                <MenuItem x:Name="NewFile" Header="新建(_N)" Click="NewFile_Click" InputGestureText="Ctrl + N"/>
                <MenuItem x:Name="OpenFile" Header="打开(_O)" Click="OpenFile_Click" InputGestureText="Ctrl + O"/>
                <MenuItem x:Name="SaveFile" Header="保存(_S)" Click="SaveFile_Click" InputGestureText="Ctrl + S"/>
                <MenuItem x:Name="SaveAsFile" Header="另存为(_A)" Click="SaveAsFile_Click"/>
                <Separator/>
                <MenuItem x:Name="ExitApp" Header="退出(_E)" Click="ExitApp_Click"/>
            </MenuItem>
            <MenuItem Header="编辑(_E)">
                <MenuItem x:Name="UndoEdit" Header="撤销(_U)" Click="UndoEdit_Click" InputGestureText="Ctrl + Z"/>
                <MenuItem x:Name="RedoEdit" Header="重做(_R)" Click="RedoEdit_Click" InputGestureText="Ctrl + Y"/>
                <Separator/>
                <MenuItem x:Name="CopyText" Header="复制(_C)" Click="CopyText_Click" InputGestureText="Ctrl + C"/>
                <MenuItem x:Name="CutText" Header="剪切(_X)" Click="CutText_Click" InputGestureText="Ctrl + X"/>
                <MenuItem x:Name="PasteText" Header="粘贴(_V)" Click="PasteText_Click" InputGestureText="Ctrl + V"/>
                <MenuItem x:Name="SelectAllText" Header="全选(_A)" Click="SelectAllText_Click" InputGestureText="Ctrl + A"/>
            </MenuItem>
            <MenuItem Header="查看(_V)">
                <MenuItem x:Name="MiWrap" Header="换行(_W)" Click="MiWrap_Click" InputGestureText="Ctrl + W"/>
            </MenuItem>
        </Menu>

        <!-- 文本编辑区域（带滚动条） -->
        <ScrollViewer Grid.Row="1">
            <TextBox
                x:Name="txtEditor" 
                AcceptsReturn="True"
                AcceptsTab="True"
                IsReadOnly="True"
                VerticalContentAlignment="Top"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto"
                FontSize="14"
                Padding="5"/>
        </ScrollViewer>
    </Grid>
</Window>
