<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Com.Scm.Wpf.Controls.Attach"
    xmlns:hc="https://handyorg.github.io/handycontrol">

    <!-- 基础色 -->
    <Color x:Key="white">#FFFFFF</Color>
    <Color x:Key="black">#000000</Color>

    <!-- 中国蓝核心色 -->
    <Color x:Key="china_blue_100">#E0EDF8</Color>
    <Color x:Key="china_blue_200">#B3D1EC</Color>
    <Color x:Key="china_blue_500">#1A68B8</Color>
    <Color x:Key="china_blue_700">#0F4A8A</Color>
    <Color x:Key="china_blue_900">#082C55</Color>

    <!-- 次要色（中国红） -->
    <Color x:Key="china_red_50">#FFF5F5</Color>
    <Color x:Key="china_red_100">#FED7D7</Color>
    <Color x:Key="china_red_500">#E53E3E</Color>
    <Color x:Key="china_red_700">#C53030</Color>
    <Color x:Key="china_red_900">#742A2A</Color>

    <!-- 中性色（水墨灰） -->
    <Color x:Key="china_neutral_50">#FFFFFF</Color>
    <Color x:Key="china_neutral_100">#F7F7F7</Color>
    <Color x:Key="china_neutral_200">#E5E5E5</Color>
    <Color x:Key="china_neutral_500">#838383</Color>
    <Color x:Key="china_neutral_700">#525252</Color>
    <Color x:Key="china_neutral_800">#2D2D2D</Color>
    <Color x:Key="china_neutral_900">#212121</Color>

    <!-- 主色调 -->
    <SolidColorBrush x:Key="ScmColorPrimary" Color="{StaticResource china_blue_500}"/>
    <SolidColorBrush x:Key="ScmColorPrimaryVariant" Color="{StaticResource china_blue_700}"/>
    <SolidColorBrush x:Key="ScmColorOnPrimary" Color="{StaticResource white}"/>

    <!-- 窗体背景 -->
    <SolidColorBrush x:Key="ScmWindowBackground" Color="{StaticResource china_neutral_100}"/>
    <!-- 面板背景 -->
    <SolidColorBrush x:Key="ScmPanelBackground" Color="{StaticResource china_neutral_50}"/>

    <SolidColorBrush x:Key="ScmBorderBrush" Color="{StaticResource china_neutral_200}"/>
    <SolidColorBrush x:Key="ScmTextColorPrimary" Color="{StaticResource china_neutral_700}"/>
    <SolidColorBrush x:Key="ScmTextColorSecondary" Color="{StaticResource china_neutral_500}"/>

    <Style TargetType="TextBlock" x:Key="InputLabel">
        <Setter Property="Margin" Value="6 0 0 0"/>
    </Style>

    <Style TargetType="Border" x:Key="PrimaryBorder">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource ScmBorderBrush}"/>
    </Style>

    <!-- 查询条件边框 -->
    <Style TargetType="Border" x:Key="SearchBorder">
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="BorderBrush" Value="{StaticResource ScmBorderBrush}"/>
        <Setter Property="Background" Value="{StaticResource ScmPanelBackground}"/>
    </Style>

    <!-- 查询结果边框 -->
    <Style TargetType="Border" x:Key="ResultBorder">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource ScmBorderBrush}"/>
        <Setter Property="Background" Value="{StaticResource ScmPanelBackground}"/>
    </Style>

    <Style TargetType="Border" x:Key="PrimaryBorderWithEffect">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="LightGray"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Gray" ShadowDepth="0" BlurRadius="5" Opacity="0.5" Direction="0"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="ControlBtnStyle">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Foreground" Value="#959595"/>
        <Setter Property="Template" >
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent" Name="back">
                        <TextBlock Text="{Binding Content, RelativeSource={RelativeSource AncestorType=Button, Mode=FindAncestor}}" 
                                   VerticalAlignment="Center" FontFamily="../../Fonts/#iconfont" HorizontalAlignment="Center" FontSize="16"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="back" Property="Background" Value="#f8f9fb"></Setter>
                            <Setter TargetName="back" Property="Opacity" Value="0.5"></Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="Button" x:Key="IconBtn">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <hc:SimplePanel>
                        <Border Background="{TemplateBinding Background}" CornerRadius="{Binding Path=(hc:BorderElement.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}"/>
                        <Border BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="{Binding Path=(hc:BorderElement.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding local:IconElement.Icon}" FontFamily="../../Fonts/MyFonts/#iconfont" FontSize="13" VerticalAlignment="Center"></TextBlock>
                                <ContentPresenter x:Name="ContentPresenterMain" RecognizesAccessKey="True" VerticalAlignment="Center" Margin="4,0,0,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </StackPanel>
                        </Border>
                    </hc:SimplePanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="Button" x:Key="AddBtnStyle" BasedOn="{StaticResource ButtonBaseStyle}">
        <Setter Property="Width" Value="80"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="BorderBrush" Value="#a3d3ff"/>
        <Setter Property="Foreground" Value="#1890ff"/>
        <Setter Property="Background" Value="#e8f4ff"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <hc:SimplePanel>
                        <Border Background="{TemplateBinding Background}" CornerRadius="{Binding Path=(hc:BorderElement.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}"/>
                        <Border BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="{Binding Path=(hc:BorderElement.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}">
                                <TextBlock Text="&#xe68d;" FontFamily="../../Fonts/MyFonts/#iconfont" FontSize="13" VerticalAlignment="Center"></TextBlock>
                                <ContentPresenter x:Name="ContentPresenterMain" RecognizesAccessKey="True" VerticalAlignment="Center" Margin="4,0,0,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </StackPanel>
                        </Border>
                    </hc:SimplePanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1890ff"/>
                <Setter Property="BorderBrush" Value="#1890ff"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="Button" x:Key="EditBtnStyle" BasedOn="{StaticResource ButtonBaseStyle}">
        <Setter Property="Width" Value="80"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="BorderBrush" Value="#a1ebc2"/>
        <Setter Property="Foreground" Value="#13ce66"/>
        <Setter Property="Background" Value="#e7faf0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <hc:SimplePanel>
                        <Border Background="{TemplateBinding Background}" CornerRadius="{Binding Path=(hc:BorderElement.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}"/>
                        <Border BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="{Binding Path=(hc:BorderElement.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}">
                                <TextBlock Text="&#xe684;" FontFamily="../../Fonts/MyFonts/#iconfont" FontSize="13" VerticalAlignment="Center"></TextBlock>
                                <ContentPresenter x:Name="ContentPresenterMain" RecognizesAccessKey="True" VerticalAlignment="Center" Margin="4,0,0,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </StackPanel>
                        </Border>
                    </hc:SimplePanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#13ce66"/>
                <Setter Property="BorderBrush" Value="#13ce66"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="Button" x:Key="DelBtnStyle" BasedOn="{StaticResource ButtonBaseStyle}">
        <Setter Property="Width" Value="80"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="BorderBrush" Value="#ffb6b6"/>
        <Setter Property="Foreground" Value="#ff4949"/>
        <Setter Property="Background" Value="#ffeded"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <hc:SimplePanel>
                        <Border Background="{TemplateBinding Background}" CornerRadius="{Binding Path=(hc:BorderElement.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}"/>
                        <Border BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="{Binding Path=(hc:BorderElement.CornerRadius),RelativeSource={RelativeSource TemplatedParent}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}">
                                <TextBlock Text="&#xe678;" FontFamily="../../Fonts/MyFonts/#iconfont" FontSize="13" VerticalAlignment="Center"></TextBlock>
                                <ContentPresenter x:Name="ContentPresenterMain" RecognizesAccessKey="True" VerticalAlignment="Center" Margin="4,0,0,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </StackPanel>
                        </Border>
                    </hc:SimplePanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#ff4949"/>
                <Setter Property="BorderBrush" Value="#ff4949"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>