<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- 基础色 -->
    <Color x:Key="white">#FFFFFF</Color>
    <Color x:Key="black">#000000</Color>

    <!-- 中国蓝核心色 -->
    <Color x:Key="china_blue_100">#E0EDF8</Color>
    <Color x:Key="china_blue_200">#B3D1EC</Color>
    <Color x:Key="china_blue_500">#1A68B8</Color>
    <Color x:Key="china_blue_700">#0F4A8A</Color>
    <Color x:Key="china_blue_900">#082C55</Color>

    <!-- 次要色（中国红） -->
    <Color x:Key="china_red_50">#FFF5F5</Color>
    <Color x:Key="china_red_100">#FED7D7</Color>
    <Color x:Key="china_red_500">#E53E3E</Color>
    <Color x:Key="china_red_700">#C53030</Color>
    <Color x:Key="china_red_900">#742A2A</Color>

    <!-- 中性色（水墨灰） -->
    <Color x:Key="china_neutral_50">#FFFFFF</Color>
    <Color x:Key="china_neutral_100">#F7F7F7</Color>
    <Color x:Key="china_neutral_200">#E5E5E5</Color>
    <Color x:Key="china_neutral_500">#838383</Color>
    <Color x:Key="china_neutral_700">#525252</Color>
    <Color x:Key="china_neutral_800">#2D2D2D</Color>
    <Color x:Key="china_neutral_900">#212121</Color>

    <!-- 主色调 -->
    <SolidColorBrush x:Key="ScmColorPrimary" Color="{StaticResource china_blue_500}"/>
    <SolidColorBrush x:Key="ScmColorPrimaryVariant" Color="{StaticResource china_blue_700}"/>
    <SolidColorBrush x:Key="ScmColorOnPrimary" Color="{StaticResource white}"/>

    <!-- 窗体背景 -->
    <SolidColorBrush x:Key="ScmWindowBackground" Color="{StaticResource china_neutral_100}"/>
    <!-- 面板背景 -->
    <SolidColorBrush x:Key="ScmPanelBackground" Color="{StaticResource china_neutral_50}"/>

    <SolidColorBrush x:Key="ScmBorderBrush" Color="{StaticResource china_neutral_200}"/>
    <SolidColorBrush x:Key="ScmTextColorPrimary" Color="{StaticResource china_neutral_700}"/>
    <SolidColorBrush x:Key="ScmTextColorSecondary" Color="{StaticResource china_neutral_500}"/>

    <Style TargetType="TextBlock" x:Key="InputLabel">
        <Setter Property="Margin" Value="6 0 0 0"/>
    </Style>

    <Style TargetType="Border" x:Key="PrimaryBorder">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource ScmBorderBrush}"/>
    </Style>

    <!-- 查询条件边框 -->
    <Style TargetType="Border" x:Key="SearchBorder">
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="BorderBrush" Value="{StaticResource ScmBorderBrush}"/>
        <Setter Property="Background" Value="{StaticResource ScmPanelBackground}"/>
    </Style>

    <!-- 查询结果边框 -->
    <Style TargetType="Border" x:Key="ResultBorder">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource ScmBorderBrush}"/>
        <Setter Property="Background" Value="{StaticResource ScmPanelBackground}"/>
    </Style>

    <Style TargetType="Border" x:Key="PrimaryBorderWithEffect">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="LightGray"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Gray" ShadowDepth="0" BlurRadius="5" Opacity="0.5" Direction="0"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 窗口按钮风格 -->
    <Style TargetType="Button" x:Key="ControlBtnStyle">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Foreground" Value="#959595"/>
        <Setter Property="Template" >
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent" Name="back">
                        <TextBlock Text="{Binding Content, RelativeSource={RelativeSource AncestorType=Button, Mode=FindAncestor}}" 
                                   VerticalAlignment="Center" FontFamily="../../Fonts/#iconfont" HorizontalAlignment="Center" FontSize="16"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="back" Property="Background" Value="#f8f9fb"></Setter>
                            <Setter TargetName="back" Property="Opacity" Value="0.5"></Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== 设计系统变量 ==================== -->

    <!-- 间距系统 (基于4px) -->
    <Thickness x:Key="ScmSpacingXs">4</Thickness>
    <Thickness x:Key="ScmSpacingSm">8</Thickness>
    <Thickness x:Key="ScmSpacingMd">12</Thickness>
    <Thickness x:Key="ScmSpacingLg">16</Thickness>
    <Thickness x:Key="ScmSpacingXl">24</Thickness>

    <!-- 圆角系统 -->
    <CornerRadius x:Key="ScmCornerRadiusSm">4</CornerRadius>
    <CornerRadius x:Key="ScmCornerRadiusMd">8</CornerRadius>
    <CornerRadius x:Key="ScmCornerRadiusLg">12</CornerRadius>

    <!-- 字体大小系统 -->
    <sys:Double x:Key="ScmFontSizeXs">12</sys:Double>
    <sys:Double x:Key="ScmFontSizeSm">13</sys:Double>
    <sys:Double x:Key="ScmFontSizeMd">14</sys:Double>
    <sys:Double x:Key="ScmFontSizeLg">16</sys:Double>
    <sys:Double x:Key="ScmFontSizeXl">24</sys:Double>
    <sys:Double x:Key="ScmFontSizeXxl">32</sys:Double>

    <!-- 阴影效果系统 -->
    <DropShadowEffect x:Key="ScmShadowSm" Color="Black" ShadowDepth="2" BlurRadius="8" Opacity="0.15" Direction="270"/>
    <DropShadowEffect x:Key="ScmShadowMd" Color="Black" ShadowDepth="4" BlurRadius="12" Opacity="0.2" Direction="270"/>
    <DropShadowEffect x:Key="ScmShadowLg" Color="Black" ShadowDepth="8" BlurRadius="16" Opacity="0.25" Direction="270"/>

    <!-- ==================== 统一组件样式 ==================== -->

    <!-- 统一卡片样式 -->
    <Style TargetType="Border" x:Key="ScmCardStyle">
        <Setter Property="Background" Value="{StaticResource ScmPanelBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ScmBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource ScmCornerRadiusMd}"/>
        <Setter Property="Padding" Value="{StaticResource ScmSpacingLg}"/>
        <Setter Property="Effect" Value="{StaticResource ScmShadowSm}"/>
    </Style>

    <!-- 主色调卡片样式 -->
    <Style TargetType="Border" x:Key="ScmCardPrimaryStyle">
        <Setter Property="Background" Value="{StaticResource ScmColorPrimary}"/>
        <Setter Property="CornerRadius" Value="{StaticResource ScmCornerRadiusMd}"/>
        <Setter Property="Padding" Value="{StaticResource ScmSpacingLg}"/>
        <Setter Property="Effect" Value="{StaticResource ScmShadowSm}"/>
    </Style>

    <!-- 统一按钮样式 -->
    <Style TargetType="Button" x:Key="ScmButtonPrimary" BasedOn="{StaticResource ButtonPrimary}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="{StaticResource ScmFontSizeMd}"/>
    </Style>

    <Style TargetType="Button" x:Key="ScmButtonDefault" BasedOn="{StaticResource ButtonDefault}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="{StaticResource ScmFontSizeMd}"/>
    </Style>

    <!-- 统一文本块样式 -->
    <Style TargetType="TextBlock" x:Key="ScmTextTitle">
        <Setter Property="FontSize" Value="{StaticResource ScmFontSizeLg}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource ScmTextColorPrimary}"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="ScmTextSubtitle">
        <Setter Property="FontSize" Value="{StaticResource ScmFontSizeSm}"/>
        <Setter Property="Foreground" Value="{StaticResource ScmTextColorSecondary}"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="ScmTextBody">
        <Setter Property="FontSize" Value="{StaticResource ScmFontSizeMd}"/>
        <Setter Property="Foreground" Value="{StaticResource ScmTextColorPrimary}"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="ScmTextValue">
        <Setter Property="FontSize" Value="{StaticResource ScmFontSizeXxl}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource ScmTextColorPrimary}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="ScmTextOnPrimary">
        <Setter Property="FontSize" Value="{StaticResource ScmFontSizeMd}"/>
        <Setter Property="Foreground" Value="{StaticResource ScmColorOnPrimary}"/>
    </Style>
</ResourceDictionary>