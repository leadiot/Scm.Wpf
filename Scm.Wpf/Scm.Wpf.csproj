<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>disable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
		<RootNamespace>Com.Scm.Wpf</RootNamespace>
		<StartupObject>Com.Scm.Wpf.App</StartupObject>
		<ApplicationIcon>oidc.ico</ApplicationIcon>
	</PropertyGroup>

	<ItemGroup>
		<Content Include="oidc.ico" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
		<PackageReference Include="CsvHelper" Version="33.0.1" />
		<PackageReference Include="HandyControl" Version="3.5.1" />
		<PackageReference Include="MahApps.Metro.IconPacks.Material" Version="5.1.0" />
		<PackageReference Include="MiniExcel" Version="1.39.0" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
		<PackageReference Include="Serilog.Sinks.Async" Version="2.1.0" />
		<PackageReference Include="Serilog.Sinks.Console" Version="6.0.0" />
		<PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
		<PackageReference Include="SqlSugarCore" Version="5.1.4.182" />
	</ItemGroup>

	<ItemGroup>
		<Reference Include="Scm.Common">
			<HintPath>..\Libs\netstandard2.0\Scm.Common.dll</HintPath>
		</Reference>
		<Reference Include="Scm.Common.Dto">
			<HintPath>..\Libs\netstandard2.0\Scm.Common.Dto.dll</HintPath>
		</Reference>
		<Reference Include="Scm.Common.Http">
			<HintPath>..\Libs\netstandard2.0\Scm.Common.Http.dll</HintPath>
		</Reference>
		<Reference Include="Scm.Common.Log">
			<HintPath>..\Libs\netstandard2.0\Scm.Common.Log.dll</HintPath>
		</Reference>
		<Reference Include="Scm.Common.Text">
			<HintPath>..\Libs\netstandard2.0\Scm.Common.Text.dll</HintPath>
		</Reference>
		<Reference Include="Scm.Common.Time">
			<HintPath>..\Libs\netstandard2.0\Scm.Common.Time.dll</HintPath>
		</Reference>
		<Reference Include="Scm.Dto">
			<HintPath>..\Libs\net8.0\Scm.Dto.dll</HintPath>
		</Reference>
	</ItemGroup>

	<ItemGroup>
	  <None Update="appsettings.json">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	</ItemGroup>

</Project>
