<UserControl
    x:Class="Com.Scm.Wpf.Controls.PageGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderThickness="0" BorderBrush="LightGray">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border
                x:Name="BdHead"
                Grid.Row="0"
                Visibility="{Binding HeadVisibility}"
                Style="{StaticResource SearchBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        x:Name="GdCustom"
                        Grid.Column="0"
                        Visibility="{Binding CustomVisibility}"
                        Orientation="Horizontal">
                    </StackPanel>
                    <StackPanel
                        x:Name="GdSearch"
                        Grid.Column="1"
                        Visibility="{Binding SearchVisibility}"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                        <hc:ElementGroup Width="160">
                            <hc:ElementGroup.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                    </Grid>
                                </ItemsPanelTemplate>
                            </hc:ElementGroup.ItemsPanel>
                            <TextBox Grid.Column="0" Text="{Binding Key}" hc:InfoElement.ShowClearButton="True"></TextBox>
                            <Button Grid.Column="1" Style="{StaticResource ButtonPrimary}" Click="BtSearch_Click">查询</Button>
                        </hc:ElementGroup>
                        <Button Margin="6 0 0 0" Visibility="{Binding MoreVisibility}" Click="ShowSearch_Click">高级</Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border
                Grid.Row="1"
                Style="{StaticResource ResultBorder}"
                Margin="0 6 0 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="BdBody" Grid.Row="0">
                        <DataGrid
                            x:Name="DgGrid"
                            ItemsSource="{Binding Items}"
                            hc:DataGridAttach.ShowRowNumber="True"
                            hc:DataGridAttach.ShowSelectAllButton="False" 
                            BorderThickness="0"
                            RowHeaderWidth="40"/>
                    </Border>
                    <Border
                        x:Name="BdFoot"
                        Grid.Row="1"
                        Visibility="{Binding FootVisibility}"
                        Background="White"
                        Padding="0 6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel
                                x:Name="GdOption"
                                Grid.Column="0"
                                Visibility="{Binding OptionVisibility}"
                                Orientation="Horizontal">
                                <hc:ButtonGroup Margin="6 0">
                                    <RadioButton Content="列表" ToolTip="列表" IsChecked="True"/>
                                    <RadioButton Content="单页" ToolTip="单页"/>
                                </hc:ButtonGroup>
                                <Button Content="刷新" ToolTip="刷新"/>
                                <Button Content="打印" ToolTip="打印"/>
                                <Button Content="导出" ToolTip="导出" Click="BtExport_Click"/>
                                <Button x:Name="BtOption" Margin="6 0 0 0" Content="选项" ToolTip="选项" Click="BtOption_Click"/>
                            </StackPanel>
                            <StackPanel
                                Name="GdPage"
                                Grid.Column="1"
                                Visibility="{Binding PageVisibility}"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="6 0">
                                <hc:Pagination
                                    Name="HpPage"
                                    Margin="6 0"
                                    MaxPageCount="{Binding PageCount}"
                                    PageIndex="{Binding PageIndex}"
                                    PageUpdated="Pagination_PageUpdated"
                                    IsJumpEnabled="True"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <hc:Drawer x:Name="DrDrawer" Dock="Right" ShowMask="True" ShowMode="Cover">
                <Border Background="White" Width="240" Padding="12">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                            <TextBlock x:Name="TbTitle" Style="{StaticResource TextBlockSubTitleBold}" Text="编辑"></TextBlock>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="BtAccept" Click="BtAccept_Click" Style="{StaticResource ButtonPrimary}" Content="确认" Margin="0 0 12 0"></Button>
                            <Button x:Name="BtSearch" Click="BtSearch_Click" Style="{StaticResource ButtonPrimary}" Content="查询" Margin="0 0 12 0"></Button>
                            <Button x:Name="BtCancel" Click="BtCancel_Click" Style="{StaticResource ButtonDefault}" Content="取消"></Button>
                        </StackPanel>
                        <Border BorderBrush="LightGray" BorderThickness="0 1" Margin="0 6">
                            <Grid x:Name="GdDrawer" Margin="0 6"></Grid>
                        </Border>
                    </DockPanel>
                </Border>
            </hc:Drawer>
        </Grid>
    </Border>
</UserControl>
